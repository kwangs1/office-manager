<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"  
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.workflow.office.org.position.mapper.PositionMapper">
	<select id="findAll" resultType="com.workflow.office.org.position.domain.Position">
		SELECT * FROM tb_position ORDER BY sec_level
	</select>
	
	<insert id="register" parameterType="com.workflow.office.org.position.domain.Position">
		INSERT INTO tb_position(
			name, sec_level
		)VALUES(
			#{name}, #{secLevel}
		)
	</insert>
	
	<update id="update" parameterType="com.workflow.office.org.position.domain.Position">
		UPDATE tb_position
		<set>
			<if test="name != null">name = #{name},</if>
			<if test="secLevel != null">sec_level = #{secLevel}</if>
		</set>
		WHERE id = #{id}
	</update>
	
	<delete id="delete" parameterType="int">
		DELETE FROM tb_position WHERE id = #{id}
	</delete>
	
	<select id="findById" resultType="com.workflow.office.org.position.domain.Position">
		SELECT * FROM tb_position WHERE id = #{id}
	</select>
</mapper>